{
  "info": {
    "_postman_id": "niya-fastapi-v3",
    "name": "Niya FastAPI",
    "description": "Multi-product FastAPI backend — Auth, Users, Orgs, Billing, Notifications, Admin Dashboard, Product Alpha, Taskboard.\n\n## Setup\n1. Import this collection and the environment file.\n2. Set `base_url` in the environment (default: http://localhost:8000).\n3. Run **Register** → **Verify Email** → **Login** — the `access_token` variable is set automatically after login.\n4. All subsequent requests use `{{access_token}}` in the Authorization header.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000", "type": "string" },
    { "key": "access_token", "value": "", "type": "string" },
    { "key": "client_key", "value": "pk_alpha_replaceme", "type": "string", "description": "Run scripts/seed_product_clients.py and paste the generated key here" },
    { "key": "org_id", "value": "", "type": "string" },
    { "key": "resource_id", "value": "", "type": "string" },
    { "key": "project_id", "value": "", "type": "string" },
    { "key": "task_id", "value": "", "type": "string" },
    { "key": "invoice_id", "value": "", "type": "string" },
    { "key": "notification_id", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "System",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
              "host": ["{{base_url}}"],
              "path": ["health"]
            },
            "description": "Returns database status, product list, and version."
          }
        },
        {
          "name": "Root",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/",
              "host": ["{{base_url}}"],
              "path": [""]
            },
            "description": "Landing page (HTML)."
          }
        }
      ]
    },
    {
      "name": "Auth",
      "description": "Registration, login, token rotation, email verification, password reset, OAuth.",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const j = pm.response.json();",
                  "  if (j.user && j.user.email) {",
                  "    pm.collectionVariables.set('registered_email', j.user.email);",
                  "    console.log('Registered:', j.user.email, '— now verify email with OTP');",
                  "  }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Product-Client-Key", "value": "{{client_key}}", "description": "Run scripts/seed_product_clients.py to generate this key" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"SecurePass123!\",\n  \"name\": \"Test User\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "register"]
            },
            "description": "Creates account and sends OTP to email. Product is identified server-side via the X-Product-Client-Key header — never from the request body. Responds 201 on success, 409 if email already exists."
          }
        },
        {
          "name": "Verify Email (OTP)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"otp\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/verify-email",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "verify-email"]
            },
            "description": "Activates account using the 6-digit OTP sent to the email."
          }
        },
        {
          "name": "Resend OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/resend-otp",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "resend-otp"]
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const j = pm.response.json();",
                  "  if (j.access_token) {",
                  "    pm.collectionVariables.set('access_token', j.access_token);",
                  "    console.log('access_token saved');",
                  "  }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Product-Client-Key", "value": "{{client_key}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"SecurePass123!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Returns access + refresh tokens in HTTP-only cookies. Also returns `access_token` in body — saved automatically to `{{access_token}}`. Returns 403 if the user has not signed up for this product."
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const j = pm.response.json();",
                  "  if (j.access_token) {",
                  "    pm.collectionVariables.set('access_token', j.access_token);",
                  "    console.log('access_token refreshed');",
                  "  }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/auth/refresh",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "refresh"]
            },
            "description": "Uses the `refresh_token` cookie to issue a new access token. Rotates refresh token."
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/forgot-password",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "forgot-password"]
            }
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"<reset-token-from-email>\",\n  \"new_password\": \"NewSecurePass123!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/reset-password",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "reset-password"]
            }
          }
        },
        {
          "name": "OAuth Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"provider_user_id\": \"google-uid-abc123\",\n  \"email\": \"user@gmail.com\",\n  \"name\": \"Google User\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/oauth/google",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "oauth", "google"]
            },
            "description": "Replace `google` with your provider name. Creates or logs in a user."
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": {
              "raw": "{{base_url}}/api/auth/logout",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "logout"]
            },
            "description": "Clears cookies and revokes the current refresh token."
          }
        },
        {
          "name": "Logout All Sessions",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": {
              "raw": "{{base_url}}/api/auth/logout-all",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "logout-all"]
            },
            "description": "Revokes all refresh tokens for the user (all devices)."
          }
        }
      ]
    },
