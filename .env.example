# =============================================================================
# Niya FastAPI Template — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# =============================================================================

# ------------------------------------------------------------------
# Database
# ------------------------------------------------------------------
# Local PostgreSQL:
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/niya_dev

# Cloud PostgreSQL (e.g. Neon, Railway, Supabase DB direct, etc.):
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname?ssl=require

# ------------------------------------------------------------------
# JWT — generate a strong secret with:  openssl rand -hex 64
# ------------------------------------------------------------------
JWT_SECRET=CHANGE_ME_use_openssl_rand_hex_64
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# ------------------------------------------------------------------
# Cookies
# ------------------------------------------------------------------
COOKIE_SECURE=false         # true in production (HTTPS only)
COOKIE_HTTPONLY=true
COOKIE_SAMESITE=lax

# ------------------------------------------------------------------
# Email (optional — for sending verification / reset emails)
# ------------------------------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your_smtp_password
EMAIL_FROM=noreply@example.com
APP_BASE_URL=http://localhost:3000

# ------------------------------------------------------------------
# Application
# ------------------------------------------------------------------
APP_NAME=Niya API
DEBUG=true
ENVIRONMENT=development
LOG_LEVEL=INFO

# ------------------------------------------------------------------
# Rate Limiting
# ------------------------------------------------------------------
RATE_LIMIT_PER_MINUTE=60

# ------------------------------------------------------------------
# CORS  (comma-separated list of allowed origins)
# ------------------------------------------------------------------
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]
